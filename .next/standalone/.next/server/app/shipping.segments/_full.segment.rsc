["$","strong",null,{"children":"Inside Dhaka City:"}]," 1–3 business days after dispatch"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Outside Dhaka (major districts):"}]," 3–6 business days after dispatch"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Remote or hard-to-reach areas:"}]," 5–10 business days after dispatch"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Large or bulky items"}]," (e.g. treadmills, gym equipment, flooring): may require additional time for freight scheduling and installation coordination"]}]]}],["$","p",null,{"children":"Delivery timelines are estimates and may be affected by weather, courier delays, public holidays, or circumstances beyond our control."}],["$","h2",null,{"children":"4. Shipping Charges"}],["$","p",null,{"children":"Shipping charges are calculated based on the delivery location, product size/weight, and order value, and will be clearly shown at checkout before you confirm your order. We may offer free or discounted shipping during promotional campaigns, which will be indicated on the relevant product or offer page."}],["$","h2",null,{"children":"5. Order Tracking"}],["$","p",null,{"children":["Once your order is dispatched, you will receive a confirmation with your courier and tracking details (where applicable) via SMS, email, or phone call. You can also check your order status anytime on our"," ",["$","a",null,{"href":"/track-order","children":"Track Your Order"}]," page using your order number."]}],["$","h2",null,{"children":"6. Large Equipment & Installation"}],["$","p",null,{"children":"For heavy or large equipment such as treadmills, multi-gyms, and flooring solutions, our team may contact you in advance to schedule a convenient delivery time and, where applicable, arrange installation or setup support."}],["$","h2",null,{"children":"7. Cash on Delivery (COD)"}],"$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26"]}]}]}]]}],null,"$L27"]}]
